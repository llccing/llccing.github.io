---
import type { CollectionEntry } from "astro:content";
import Layout from "@layouts/Layout.astro";
import Main from "@layouts/Main.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import Pagination from "@components/Pagination.astro";
import Card from "@components/Card";
import { SITE } from "@config";

export interface Props {
  currentPage: number;
  totalPages: number;
  paginatedPosts: (
    | CollectionEntry<"blog">
    | CollectionEntry<"short-stories">
  )[];
  collection?: "blog" | "short-stories";
}

const { currentPage, totalPages, paginatedPosts, collection = "blog" } = Astro.props;

const basePath = collection === "short-stories" ? "/short-stories" : "/posts";
---

<Layout title={`${collection === "short-stories" ? "Short Stories" : "Posts"} | ${SITE.title}`}>
  <Header activeNav={collection === "short-stories" ? "short-stories" : "posts"} />
  <Main 
    pageTitle={collection === "short-stories" ? "Short Stories" : "Posts"} 
    pageDesc={collection === "short-stories" ? "All the short stories I've written." : "All the articles I've posted."}
  >
    <ul>
      {
        paginatedPosts.map(({ data, slug }) => (
          <Card href={`${basePath}/${slug}/`} frontmatter={data} />
        ))
      }
    </ul>
  </Main>

  <Pagination
    {currentPage}
    {totalPages}
    prevUrl={`${basePath}${currentPage - 1 !== 1 ? "/" + (currentPage - 1) : ""}/`}
    nextUrl={`${basePath}/${currentPage + 1}/`}
  />

  <Footer noMarginTop={totalPages > 1} />
</Layout>
