---
const gaMeasurementId = import.meta.env.PUBLIC_GA_MEASUREMENT_ID;
const shouldLoadAnalytics = import.meta.env.PROD && gaMeasurementId;
---

{
  shouldLoadAnalytics && (
    <>
      <script
        is:inline
        async
        src={`https://www.googletagmanager.com/gtag/js?id=${gaMeasurementId}`}
      />
      <script is:inline define:vars={{ gaMeasurementId }}>
        window.dataLayer = window.dataLayer || []; const gtag = (...args) =>
        window.dataLayer.push(args); gtag("js", new Date()); gtag("config",
        gaMeasurementId);
      </script>
    </>
  )
}
